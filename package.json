{
  "name": "speaktype",
  "private": true,
  "scripts": {
    "dev:extension": "pnpm --filter @speaktype/extension dev",
    "dev:backend": "pnpm --filter @speaktype/backend dev",
    "build": "pnpm -r build",
    "build:extension": "pnpm --filter @speaktype/extension build",
    "build:backend": "pnpm --filter @speaktype/backend build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "typescript-eslint": "^8.12.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.3.3",
    "globals": "^15.11.0"
  }
}
