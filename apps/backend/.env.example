# --- Database Connections ---
# Neon PostgreSQL pooled connection string (used by application runtime queries)
DATABASE_URL="postgres://user:password@ep-pool-name.region.pooler.neon.tech/neondb?sslmode=require"
# Neon PostgreSQL unpooled/direct connection string (used only for schema migrations)
DATABASE_URL_UNPOOLED="postgres://user:password@ep-pool-name.region.neon.tech/neondb?sslmode=require"

# --- Redis Configuration (Upstash) ---
# Upstash Redis REST API endpoint URL for caching, quota and rate limiting
UPSTASH_REDIS_REST_URL="https://your-redis-name.upstash.io"
# Upstash Redis REST API token
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"

# --- AI & STT Providers ---
# Groq API Key for fast speech-to-text (Whisper)
GROQ_API_KEY="gsk_your_groq_api_key_here"
# Groq Whisper model name (default: whisper-large-v3-turbo)
GROQ_MODEL="whisper-large-v3-turbo"
# Google Gemini API Key for transcription text cleanup
GEMINI_API_KEY="your_gemini_api_key_here"
# Google Gemini model name (default: gemini-2.5-flash)
GEMINI_MODEL="gemini-2.5-flash"

# --- Security & JWT Auth ---
# Secret key used to sign JWT access tokens
JWT_SECRET="your_jwt_secret_hex_or_string_here"
# Time-to-live for access tokens, in seconds (default: 900)
ACCESS_TOKEN_TTL_SECONDS=900
# Time-to-live for refresh tokens, in days (default: 30)
REFRESH_TOKEN_TTL_DAYS=30

# --- BetterAuth Configuration ---
# Secret key for BetterAuth core operations and security (generate via 'openssl rand -hex 32')
BETTER_AUTH_SECRET="your_better_auth_secret_here"
# Root URL of the Nuxt backend (default: http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# --- CORS Allowlist ---
# Comma-separated list of allowed origins. Must include chrome-extension://<extension-id> and http://localhost:3000
CORS_ORIGINS="chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef,http://localhost:3000"
