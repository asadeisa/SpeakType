# SpeakType — Backend Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# ---------------------------------------------------------------------------
# Database — Neon Postgres (https://neon.tech)
# ---------------------------------------------------------------------------
# Connection string for the serverless Postgres instance.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/speaktype?sslmode=require

# ---------------------------------------------------------------------------
# BetterAuth — Authentication (https://better-auth.com)
# ---------------------------------------------------------------------------
# A long random secret used to sign sessions and tokens.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-long-random-secret-here

# The canonical base URL of this backend (used for redirects & cookies).
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Upstash Redis — Rate-limiting & queuing (https://upstash.com)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# ---------------------------------------------------------------------------
# Groq — Whisper speech-to-text transcription (https://console.groq.com)
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Google Gemini — AI text cleanup (https://aistudio.google.com)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# App / server settings
# ---------------------------------------------------------------------------
# Port the Nuxt dev server listens on (default: 3000).
PORT=3000

# Set to "production" in deployed environments.
NODE_ENV=development
