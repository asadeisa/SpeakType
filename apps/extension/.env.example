# apps/extension/.env.example — copy to apps/extension/.env to override defaults.
# Only vars prefixed WXT_ are inlined into the extension bundle by WXT.

# Backend API base URL the extension talks to.
# Leave unset for local dev (defaults to http://localhost:3000/api).
# Set to your deployed backend for a production build, e.g.:
#   WXT_API_URL=https://api.speaktype.example/api
WXT_API_URL=
