# SpeakType — Browser Extension Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env file.
#
# WXT exposes variables prefixed with VITE_ to the extension bundle at build time.

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Base URL of the SpeakType backend the extension talks to.
VITE_API_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Groq — Whisper speech-to-text
# ---------------------------------------------------------------------------
# Create a key at https://console.groq.com
VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Google Gemini — AI text cleanup
# ---------------------------------------------------------------------------
# Create a key at https://aistudio.google.com
VITE_GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Extension build settings
# ---------------------------------------------------------------------------
# Target browser: "chrome" | "firefox" | "safari"
WXT_BROWSER=chrome
