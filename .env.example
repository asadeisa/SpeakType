# .env.example — copy to apps/backend/.env and fill in real values.
# Keys only — never put real secrets here.

# ---------------------------------------------------------------------------
# Database (Neon Postgres)
# Get both URLs from your Neon project dashboard → Connection Details.
# ---------------------------------------------------------------------------

# Pooled connection — used at runtime by Nitro / @neondatabase/serverless.
DATABASE_URL=postgresql://<user>:<password>@<pooler-host>/<dbname>?sslmode=require&channel_binding=require

# Direct / unpooled connection — used by drizzle-kit generate + migrate.
# Required for DDL; the pooler cannot run migrations reliably.
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<direct-host>/<dbname>?sslmode=require&channel_binding=require

# ---------------------------------------------------------------------------
# Auth (BetterAuth)
# ---------------------------------------------------------------------------

# Random base-64 secret (e.g. openssl rand -base64 32).
BETTER_AUTH_SECRET=

# Public base URL of this Nitro server (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cache / rate-limiting (Upstash Redis) — Phase 2
# ---------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# STT — Groq Whisper (primary) — Phase 2
# Free tier: ~2 000 req/day. Get key at console.groq.com.
# ---------------------------------------------------------------------------

GROQ_API_KEY=

# ---------------------------------------------------------------------------
# AI cleanup — Google Gemini (free tier) — Phase 2
# Get key at aistudio.google.com/app/apikey.
# ---------------------------------------------------------------------------

GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Billing — Stripe (deferred — Phase 3+)
# ---------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
